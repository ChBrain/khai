{
  "name": "@chbrain/khai-workspace",
  "version": "0.0.0",
  "private": true,
  "description": "khai monorepo \u2014 the architecture canon and the engine content packages that conform to it.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/chbrain/khai.git"
  },
  "license": "SEE LICENSE IN LICENSE and LICENSE-CODE",
  "workspaces": [
    "packages/khai-arch",
    "packages/khai-rules",
    "packages/khai-guard",
    "packages/khai-tests",
    "packages/khai-review",
    "packages/khai-skills",
    "packages/khai-pack",
    "packages/khai-methods",
    "packages/khai-stage",
    "packages/khai-plays",
    "packages/khai-language",
    "packages/khai-tour",
    "packages/engines/*",
    "packages/composites/*"
  ],
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "test": "npm test --workspaces --if-present",
    "build:skills": "npm run build -w @chbrain/khai-skills",
    "check:skills": "npm run check -w @chbrain/khai-skills",
    "drift:skills": "npm run drift -w @chbrain/khai-skills",
    "build:methods": "npm run build -w @chbrain/khai-methods",
    "verify:methods": "npm run verify -w @chbrain/khai-methods",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "changeset publish",
    "prepare": "husky"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.1",
    "husky": "^9.1.6",
    "prettier": "^3.9.6"
  },
  "overrides": {
    "read-yaml-file": "^2.1.0"
  }
}
