{
  "name": "@chbrain/khai-skills",
  "version": "0.0.8",
  "description": "khai skills kit — self-contained, vendor-neutral Agent Skills built from the khai-arch canon, so cheaper or non-code-aware models can do khai work to the agentskills.io standard.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/chbrain/khai.git",
    "directory": "packages/khai-skills"
  },
  "license": "SEE LICENSE IN LICENSE and LICENSE-CODE",
  "tagline": "Self-contained skill bundles built from the khai-arch canon. Drop one into any project and the agent knows how to use it.",
  "type": "module",
  "main": "./lib/guard.mjs",
  "exports": {
    ".": "./lib/guard.mjs",
    "./build": "./lib/build.mjs",
    "./package.json": "./package.json"
  },
  "bin": {
    "khai-skills": "./bin/khai-skills.mjs"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  },
  "files": [
    "bin/",
    "lib/",
    "src/",
    "standards/",
    "README.md"
  ],
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "build": "node bin/khai-skills.mjs build",
    "check": "node bin/khai-skills.mjs check",
    "drift": "node bin/khai-skills.mjs drift",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@chbrain/khai-arch": "^0.1.3",
    "@chbrain/khai-pack": "^0.0.3",
    "gray-matter": "^4.0.3"
  },
  "devDependencies": {
    "vitest": "^4.1.8"
  }
}
