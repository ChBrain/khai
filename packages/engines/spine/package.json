{
  "name": "@chbrain/khai-engine-spine",
  "version": "0.1.1",
  "description": "khai engine, the spine domain: the meta layer a world runs on, the collaboration contract and the architecture (the extension point), with a setup plan that routes a world into a host.",
  "type": "module",
  "main": "./index.mjs",
  "exports": {
    ".": "./index.mjs",
    "./package.json": "./package.json"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/chbrain/khai.git",
    "directory": "packages/engines/spine"
  },
  "license": "SEE LICENSE IN LICENSE and LICENSE-CODE",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  },
  "files": [
    "index.mjs",
    "*.md"
  ],
  "khai": {
    "engine": "spine",
    "class": "meta",
    "tagline": "The spine a world runs on: a setup plan routing to each host, on the neutral collaboration contract and the architecture (the extension point).",
    "members": [
      {
        "file": "plan_setup.md",
        "type": "plan",
        "parent": null
      },
      {
        "file": "instructions.md",
        "type": "instructions",
        "parent": "plan_setup.md"
      },
      {
        "file": "architecture.md",
        "type": "architecture",
        "parent": "plan_setup.md"
      }
    ],
    "extensions": {
      "instructions.md": [
        "Play Mode",
        "Analysis Mode"
      ]
    }
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "vitest": "^4.1.8"
  }
}
