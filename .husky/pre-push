#!/usr/bin/env sh
# KHAI-Guard: block a push that would mix source and test changes in a single
# PR range (compare branch tip against its merge-base with origin/main).
npx khai-guard

# KHAI-Guard branch-scope: the branch NAME must classify into a lane, and the
# branch's diff range must stay inside that lane. ENFORCED (exit 1 on a
# violation). Pick the lane with `khai-guard advise --files <paths>` before
# `git checkout -b`; see docs/BRANCHING.md.
#
# The hook receives the branch being pushed on stdin.
# Format: <local ref> <local sha> <remote ref> <remote sha>
while read local_ref local_sha remote_ref remote_sha
do
  case "$local_ref" in
    refs/heads/*)
      branch_name="${local_ref#refs/heads/}"
      echo "KHAI-Guard: checking branch '$branch_name'..."
      npx khai-guard branch-check --branch "$branch_name"
      ;;
  esac
done

# KHAI-Guard bump-scope: flag a non-patch release scope. minor/major is the
# maintainer's call; this prints the loud banner locally so you see it before
# the PR exists. Advisory -- never blocks the push (CI stamps the label).
npx khai-guard bump-check

# KHAI-Guard lockfile-scope: reject a lockfile committed inside a package. This
# is an npm-workspaces monorepo; the root package-lock.json is the only
# authoritative lock, so a stray nested lock desyncs Dependabot and CI. ENFORCED.
npx khai-guard lockfile-check
