#!/usr/bin/env sh
# Pre-commit guard: khai conformance — any engine/canon .md staged must
# still conform to the canon (the same validator CI runs).
#
# The source/test separation rule (formerly an inline "META-2" block here)
# now lives in KHAI-Guard at PRE-PUSH, where it sees the whole PR range.
# A per-commit check was the wrong granularity — it tripped on legitimate
# multi-commit branches that split content and tooling across commits.

# Guard: reject any staged tarballs (should never be committed)
if git diff --cached --name-only | grep -E '\.(tgz|tar\.gz)$'; then
  echo "❌ Error: Tarball files (.tgz/.tar.gz) should not be committed. Use a registry instead."
  exit 1
fi

STAGED=$(git diff --cached --name-status -M --diff-filter=ACMR | awk '
  $1 == "R100" || $1 == "C100" { next }
  $1 ~ /^[RC]/ { print $3; next }
  { print $2 }
')

STAGED_MD=$(echo "$STAGED" | grep -E '\.md$' || true)
if [ -n "$STAGED_MD" ]; then
  node packages/khai-tests/src/cli.mjs $STAGED_MD || exit 1
fi

exit 0
