#!/usr/bin/env sh
# Pre-commit guards:
#   META-2  — content (architecture/) and tooling (tests/.github/.husky) must
#             not land in the same commit. Governs EDITS, not pure file moves:
#             pure renames (R100/C100) are exempt; a rename-with-edit is judged
#             by its destination path.
#   khai conformance — any engine package touched by staged .md content must
#             still conform to the canon (same validator CI runs).

STAGED=$(git diff --cached --name-status -M --diff-filter=ACMRD | awk '
  $1 == "R100" || $1 == "C100" { next }
  $1 ~ /^[RC]/ { print $3; next }
  { print $2 }
')

HAS_SOURCE=0
HAS_TEST=0

for f in $STAGED; do
  case "$f" in
    packages/khai-arch/architecture/*) HAS_SOURCE=1 ;;
    packages/khai-arch/tests/*|.github/workflows/*|.husky/*) HAS_TEST=1 ;;
  esac
done

if [ "$HAS_SOURCE" -eq 1 ] && [ "$HAS_TEST" -eq 1 ]; then
  echo "META-2 violation: cannot mix architecture/ content with tests/.github/.husky/ in the same commit."
  echo "Split into two commits: one for content, one for tooling."
  exit 1
fi

STAGED_MD=$(echo "$STAGED" | grep -E '\.md$' || true)
if [ -n "$STAGED_MD" ]; then
  node packages/khai-tests/src/cli.mjs $STAGED_MD || exit 1
fi

exit 0
