{
  "source": [
    "packages/khai-arch/architecture/**",
    "packages/khai-guard/index.mjs",
    "packages/khai-guard/bin/**"
  ],
  "test": [
    "packages/khai-arch/tests/**",
    "packages/khai-guard/tests/**",
    ".github/workflows/**",
    ".husky/**"
  ],
  "bumpScope": {
    "freeLevel": "patch",
    "labels": {
      "minor": "bump:minor",
      "major": "bump:major"
    }
  },
  "licensePolicy": {
    "packages": ["packages/*/package.json", "packages/engines/*/package.json"],
    "packageLicenses": ["SEE LICENSE IN LICENSE and LICENSE-CODE"],
    "skills": ["packages/khai-skills/src/*/SKILL.md"],
    "skillLicenses": ["CC-BY-NC-4.0", "CC-BY-NC-SA-4.0"]
  },
  "lockfilePolicy": {
    "lockfiles": ["package-lock.json", "npm-shrinkwrap.json"],
    "allowRoot": true
  },
  "exemptRenames": true,
  "branchScope": {
    "shared": [".changeset/**", "package.json", "package-lock.json", "docs/SCIENCE.md"],
    "lanes": [
      {
        "pattern": "arch/*",
        "layer": "architecture",
        "allow": ["packages/khai-arch/**"]
      },
      {
        "pattern": "governance/*",
        "layer": "governance",
        "allow": [
          "packages/khai-guard/**",
          "packages/khai-tests/**",
          "packages/khai-rules/**",
          "packages/khai-pack/**",
          "packages/khai-language/**",
          ".github/**",
          ".husky/**",
          "khai-guard.config.json",
          ".prettierignore",
          "docs/BRANCHING.md",
          "CLAUDE.md",
          "GEMINI.md",
          ".github/copilot-instructions.md"
        ]
      },
      {
        "pattern": "engine/*/*",
        "layer": "solution",
        "unit": 1,
        "allow": ["packages/engines/{name}/**"]
      },
      {
        "pattern": "skills/*",
        "layer": "solution",
        "allow": ["packages/khai-skills/**", "docs/SKILLS.md"]
      },
      {
        "pattern": "methods/*",
        "layer": "solution",
        "allow": ["packages/khai-methods/**", "docs/METHODS.md"]
      },
      {
        "pattern": "stage/*",
        "layer": "solution",
        "allow": ["packages/khai-stage/**"]
      },
      {
        "pattern": "review/*",
        "layer": "solution",
        "allow": ["packages/khai-review/**"]
      },
      {
        "pattern": "plays/*",
        "layer": "solution",
        "allow": ["packages/khai-plays/**"]
      },
      {
        "pattern": "tour/*",
        "layer": "solution",
        "allow": ["packages/khai-tour/**"]
      },
      {
        "pattern": "examples/*",
        "layer": "solution",
        "allow": ["examples/**"]
      },
      {
        "pattern": "dependabot/*",
        "layer": "deps",
        "allow": ["**/package.json", "**/package-lock.json", ".github/workflows/**"]
      },
      {
        "pattern": "repo/*",
        "layer": "infra",
        "allow": []
      },
      {
        "pattern": "chore/*",
        "layer": "general",
        "allow": []
      },
      {
        "pattern": "fix/*",
        "layer": "general",
        "allow": []
      },
      {
        "pattern": "docs/*",
        "layer": "general",
        "allow": []
      }
    ]
  }
}
